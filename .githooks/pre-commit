#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
meaningful_test_script="$repo_root/quality/scripts/check_meaningful_tests.sh"
format_script="$repo_root/quality/scripts/kotlin_detekt_format.sh"
quality_script="$repo_root/quality/scripts/kotlin_quality_check.sh"
kotlin_env_script="$repo_root/quality/scripts/kotlin_toolchain_env.sh"

if [ ! -f "$kotlin_env_script" ]; then
  echo "pre-commit: Kotlin Toolchain env script not found: $kotlin_env_script" >&2
  exit 1
fi

# shellcheck source=quality/scripts/kotlin_toolchain_env.sh
source "$kotlin_env_script"
lomo_kotlin_prepare_env "pre-commit"

staged_kotlin_files=()
while IFS= read -r -d '' file; do
  staged_kotlin_files+=("$file")
done < <(git -C "$repo_root" diff --cached --name-only --diff-filter=ACMR -z -- '*.kt' '*.kts')

if [ ${#staged_kotlin_files[@]} -gt 0 ]; then
  unstaged_diff="$(git -C "$repo_root" rev-parse --git-path "unstaged-detekt-git-hook-$$.diff")"
  unstaged_diff_reversed=0

  cleanup() {
    local exit_code=$?
    trap - EXIT INT TERM
    if [ "$unstaged_diff_reversed" -eq 1 ] && [ -f "$unstaged_diff" ] && [ -s "$unstaged_diff" ]; then
      git -C "$repo_root" apply --ignore-whitespace "$unstaged_diff" || true
    fi
    rm -f "$unstaged_diff"
    exit "$exit_code"
  }

  trap cleanup EXIT INT TERM

  git -C "$repo_root" diff --binary --color=never -- "${staged_kotlin_files[@]}" >"$unstaged_diff"
  if [ -s "$unstaged_diff" ]; then
    git -C "$repo_root" apply -R "$unstaged_diff"
    unstaged_diff_reversed=1
  fi

  echo "pre-commit: formatting staged Kotlin files via detekt CLI..."
  "$format_script" staged
  echo "pre-commit: format pass finished"

  for file in "${staged_kotlin_files[@]}"; do
    if [ -f "$repo_root/$file" ]; then
      git -C "$repo_root" add -- "$file"
    fi
  done
else
  echo "pre-commit: no staged Kotlin files; skipping format."
fi

if [ ! -x "$meaningful_test_script" ]; then
  echo "pre-commit: meaningful test check script not found or not executable: $meaningful_test_script" >&2
  exit 1
fi

echo "pre-commit: checking meaningful test contracts on staged tests..."
MEANINGFUL_TEST_CHECK_MODE=staged "$meaningful_test_script"

if [ ! -x "$quality_script" ]; then
  echo "pre-commit: quality script not found or not executable: $quality_script" >&2
  exit 1
fi

echo "pre-commit: running repository quality gate before commit..."
"$quality_script"
