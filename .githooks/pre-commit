#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
gradlew="$repo_root/gradlew"
meaningful_test_script="$repo_root/quality/scripts/check_meaningful_tests.sh"
quality_script="$repo_root/quality/scripts/ai_quality_check.sh"

staged_kotlin_files=()
while IFS= read -r -d '' file; do
  staged_kotlin_files+=("$file")
done < <(git -C "$repo_root" diff --cached --name-only --diff-filter=ACMR -z -- '*.kt' '*.kts')

if [ ! -x "$gradlew" ]; then
  echo "pre-commit: gradle wrapper not found or not executable: $gradlew" >&2
  exit 1
fi

hook_gradle_user_home="$repo_root/.gradle/pre-commit-user-home"
mkdir -p "$hook_gradle_user_home"
wrapper_dists_dir="$hook_gradle_user_home/wrapper/dists"

clear_stale_wrapper_locks() {
  local lock_file
  local removed_count=0

  while IFS= read -r -d '' lock_file; do
    local ok_file="${lock_file%.lck}.ok"
    if [ -f "$ok_file" ]; then
      rm -f "$lock_file"
      removed_count=$((removed_count + 1))
    fi
  done < <(find "$wrapper_dists_dir" -type f -name '*.zip.lck' -print0 2>/dev/null)

  if [ "$removed_count" -gt 0 ]; then
    echo "pre-commit: removed $removed_count stale Gradle wrapper lock(s)"
  fi
}

clear_stale_wrapper_locks

if [ ${#staged_kotlin_files[@]} -gt 0 ]; then
  printf -v staged_kotlin_git_filter '%s\n' "${staged_kotlin_files[@]}"
  unstaged_diff="$(git -C "$repo_root" rev-parse --git-path "unstaged-detekt-git-hook-$$.diff")"
  unstaged_diff_reversed=0

  cleanup() {
    local exit_code=$?
    trap - EXIT INT TERM
    if [ "$unstaged_diff_reversed" -eq 1 ] && [ -f "$unstaged_diff" ] && [ -s "$unstaged_diff" ]; then
      git -C "$repo_root" apply --ignore-whitespace "$unstaged_diff"
    fi
    rm -f "$unstaged_diff"
    exit "$exit_code"
  }

  trap cleanup EXIT INT TERM

  git -C "$repo_root" diff --binary --color=never -- "${staged_kotlin_files[@]}" > "$unstaged_diff"
  if [ -s "$unstaged_diff" ]; then
    git -C "$repo_root" apply -R "$unstaged_diff"
    unstaged_diff_reversed=1
  fi

  echo "pre-commit: running $gradlew detektFormatStaged on staged Kotlin files..."
  echo "pre-commit: using repo-local GRADLE_USER_HOME at $hook_gradle_user_home"
  GRADLE_USER_HOME="$hook_gradle_user_home" \
    "$gradlew" --project-dir "$repo_root" --no-daemon --no-configuration-cache --quiet \
    detektFormatStaged "-PinternalDetektGitFilter=$staged_kotlin_git_filter"
  echo "pre-commit: detektFormatStaged finished"

  # Re-stage files that were modified by formatter.
  for file in "${staged_kotlin_files[@]}"; do
    if [ -f "$repo_root/$file" ]; then
      git -C "$repo_root" add -- "$file"
    fi
  done
else
  echo "pre-commit: no staged Kotlin files; skipping detektFormatStaged."
fi

if [ ! -x "$meaningful_test_script" ]; then
  echo "pre-commit: meaningful test check script not found or not executable: $meaningful_test_script" >&2
  exit 1
fi

echo "pre-commit: checking meaningful test contracts on staged tests..."
MEANINGFUL_TEST_CHECK_MODE=staged "$meaningful_test_script"

if [ ! -x "$quality_script" ]; then
  echo "pre-commit: quality script not found or not executable: $quality_script" >&2
  exit 1
fi

echo "pre-commit: running repository quality gate before commit..."
"$quality_script"
