#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
gradlew="$repo_root/gradlew"

staged_kotlin_files=()
while IFS= read -r -d '' file; do
  staged_kotlin_files+=("$file")
done < <(git -C "$repo_root" diff --cached --name-only --diff-filter=ACMR -z -- '*.kt' '*.kts')

if [ ${#staged_kotlin_files[@]} -eq 0 ]; then
  exit 0
fi

if [ ! -x "$gradlew" ]; then
  echo "pre-commit: gradle wrapper not found or not executable: $gradlew" >&2
  exit 1
fi

hook_gradle_user_home="$repo_root/.gradle/pre-commit-user-home"
mkdir -p "$hook_gradle_user_home"
wrapper_dists_dir="$hook_gradle_user_home/wrapper/dists"

clear_stale_wrapper_locks() {
  local lock_file
  local removed_count=0

  while IFS= read -r -d '' lock_file; do
    local ok_file="${lock_file%.lck}.ok"
    if [ -f "$ok_file" ]; then
      rm -f "$lock_file"
      removed_count=$((removed_count + 1))
    fi
  done < <(find "$wrapper_dists_dir" -type f -name '*.zip.lck' -print0 2>/dev/null)

  if [ "$removed_count" -gt 0 ]; then
    echo "pre-commit: removed $removed_count stale Gradle wrapper lock(s)"
  fi
}

clear_stale_wrapper_locks

printf -v staged_kotlin_git_filter '%s\n' "${staged_kotlin_files[@]}"
unstaged_diff="$(git -C "$repo_root" rev-parse --git-path "unstaged-ktlint-git-hook-$$.diff")"
unstaged_diff_reversed=0

cleanup() {
  local exit_code=$?
  trap - EXIT INT TERM
  if [ "$unstaged_diff_reversed" -eq 1 ] && [ -f "$unstaged_diff" ] && [ -s "$unstaged_diff" ]; then
    git -C "$repo_root" apply --ignore-whitespace "$unstaged_diff"
  fi
  rm -f "$unstaged_diff"
  exit "$exit_code"
}

trap cleanup EXIT INT TERM

git -C "$repo_root" diff --binary --color=never -- "${staged_kotlin_files[@]}" > "$unstaged_diff"
if [ -s "$unstaged_diff" ]; then
  git -C "$repo_root" apply -R "$unstaged_diff"
  unstaged_diff_reversed=1
fi

echo "pre-commit: running $gradlew ktlintFormat on staged Kotlin files..."
echo "pre-commit: using repo-local GRADLE_USER_HOME at $hook_gradle_user_home"
GRADLE_USER_HOME="$hook_gradle_user_home" \
  "$gradlew" --project-dir "$repo_root" --no-daemon --quiet \
  ktlintFormat "-PinternalKtlintGitFilter=$staged_kotlin_git_filter"
echo "pre-commit: ktlintFormat finished"

# Re-stage files that were modified by formatter.
for file in "${staged_kotlin_files[@]}"; do
  if [ -f "$repo_root/$file" ]; then
    git -C "$repo_root" add -- "$file"
  fi
done
